{
  "outputDirectory": "public",
  "functions": {
    "api/**/*.php": {
      "runtime": "vercel-php@0.9.0"
    }
  },
  "routes": [
    {
      "src": "/assets/(.*)",
      "dest": "/assets/$1"
    },
    {
      "src": "/admin/(.*)\\.php",
      "dest": "/api/admin/$1"
    },
    {
      "src": "/doctor/(.*)\\.php",
      "dest": "/api/doctor/$1"
    },
    {
      "src": "/patient/(.*)\\.php",
      "dest": "/api/patient/$1"
    },
    {
      "src": "/$",
      "dest": "/api/index"
    },
    {
      "src": "/(.*)\\.php",
      "dest": "/api/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/api/$1"
    }
  ]
}
