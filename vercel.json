{
  "outputDirectory": ".",
  "functions": {
    "api/**/*.php": {
      "runtime": "vercel-php@0.9.0"
    }
  },
  "routes": [
    {
      "src": "/assets/(.*)",
      "dest": "/assets/$1"
    },
    {
      "src": "/admin/(.*)",
      "dest": "/api/admin/$1"
    },
    {
      "src": "/doctor/(.*)",
      "dest": "/api/doctor/$1"
    },
    {
      "src": "/patient/(.*)",
      "dest": "/api/patient/$1"
    },
    {
      "src": "/$",
      "dest": "/api/index.php"
    },
    {
      "src": "/(.*)",
      "dest": "/api/$1"
    }
  ]
}
